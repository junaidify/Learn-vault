{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://learn-vault-1.onrender.com/api/:path*"
    },
    {
      "source": "/oauth2/:path*",
      "destination": "https://learn-vault-1.onrender.com/oauth2/:path*"
    },
    {
      "source": "/login/oauth2/:path*",
      "destination": "https://learn-vault-1.onrender.com/login/oauth2/:path*"
    },
    {
      "source": "/((?!api|oauth2|login/oauth2).*)" ,
      "destination": "/index.html"
    }
  ]
}
